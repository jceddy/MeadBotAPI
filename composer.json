{
    "name": "meadbot/meadbot-api",
    "description": "REST API exposing MeadBot's mead-brewing calculator functionality",
    "type": "project",
    "license": "GPL-3.0-only",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "MeadBotApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MeadBotApi\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "serve": "php -S 0.0.0.0:8000 -t public",
        "docs": "php -S 0.0.0.0:8080 -t docs"
    }
}
